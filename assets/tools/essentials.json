[
  {
    "name": "Hekate",
    "description": "Nintendo Switch bootloader with GUI, payload launcher, and emuMMC support.",
    "checkPath": "bootloader",
    "steps": [
      {
        "type": "github_zip",
        "owner": "CTCaer",
        "repo": "hekate",
        "assetMatch": "hekate_ctcaer_",
        "extractTo": ""
      },
      {
        "type": "direct_zip",
        "url": "https://switch.hacks.guide/files/bootlogos.zip",
        "extractTo": ""
      },
      {
        "type": "direct_file",
        "url": "https://raw.githubusercontent.com/souldbminerr/extras/refs/heads/main/hekate_ipl.ini",
        "dest": "bootloader/hekate_ipl.ini"
      },
      {
        "type": "direct_file",
        "url": "https://raw.githubusercontent.com/souldbminerr/extras/refs/heads/main/safemode.ini",
        "dest": "bootloader/ini/safemode.ini"
      }
    ]
  },
  {
    "name": "Atmosphere",
    "description": "Nintendo Switch custom firmware. Includes hbmenu and DNS block for emuMMC.",
    "checkPath": "atmosphere",
    "steps": [
      {
        "type": "github_zip",
        "owner": "Atmosphere-NX",
        "repo": "Atmosphere",
        "assetMatch": "hbmenu-",
        "assetExclude": "symbols",
        "extractTo": ""
      },
      {
        "type": "direct_file",
        "url": "https://switch.hacks.guide/files/emummc.txt",
        "dest": "atmosphere/hosts/emummc.txt"
      },
      {
        "type": "direct_file",
        "url": "https://raw.githubusercontent.com/souldbminerr/extras/refs/heads/main/system_settings.ini",
        "dest": "atmosphere/config/system_settings.ini"
      }
    ]
  },
  {
    "name": "Update Blocker",
    "description": "Blocks system updates.",
    "checkPath": "atmosphere/hosts/sysmmc.txt",
    "steps": [
      {
        "type": "direct_file",
        "url": "https://raw.githubusercontent.com/souldbminerr/tiny-switch-aio-pack/refs/heads/main/atmosphere/hosts/default.txt",
        "dest": "atmosphere/hosts/sysmmc.txt"
      }
    ]
  }
]
